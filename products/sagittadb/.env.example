# SagittaDB Enterprise 客户部署环境变量。
# 启动前复制为 .env，并替换所有 CHANGE_ME 值。

POSTGRES_DB=sagittadb
POSTGRES_USER=sagitta
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# 生产环境必须使用稳定的 32 位以上随机密钥。
# 数据加密后不要再修改 SECRET_KEY。
SECRET_KEY=CHANGE_ME_RANDOM_32_PLUS_CHARS

# SagittaDB Enterprise 授权校验。
# LICENSE_PUBLIC_KEY 是官方 License-Server-Center 的验签公钥，不是密钥。
# 在线激活和联网刷新会自动提交授权项目码 sagittadb。
# 仅在使用私有授权中心或公钥轮换时替换。
LICENSE_PUBLIC_KEY=3Jz3SK-mTWZwGy6VX8gUBUWJ-kisvGnO3c_x18Fk_Ms
LICENSE_CUSTOMER_ID=
LICENSE_SERVER_URL=https://sagitta.loveai.asia
LICENSE_AUTO_REFRESH_ENABLED=true
LICENSE_RENEWAL_NOTIFY_DAYS=30,7
LICENSE_TRIAL_DAYS=30
# 商业 License 部署指纹绑定使用的稳定部署 ID。
# 首次部署生成一次，升级时保持不变，不要在日志中公开。
LICENSE_DEPLOYMENT_ID=CHANGE_ME_STABLE_RANDOM_DEPLOYMENT_ID
LICENSE_OFFLINE_CHALLENGE_TTL_MINUTES=60
LICENSE_ALLOW_LEGACY_LICENSE_IMPORT=false

# 商业镜像完整性校验。MANIFEST_PUBLIC_KEY 为空时复用 LICENSE_PUBLIC_KEY。
APP_INTEGRITY_REQUIRED=true
APP_INTEGRITY_MANIFEST=/app/COMMERCIAL-MANIFEST.json
APP_INTEGRITY_ROOT=/app
MANIFEST_PUBLIC_KEY=

APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING

BACKEND_PORT=8000
FRONTEND_PORT=80
CELERY_CONCURRENCY=8

ENABLE_GOINCEPTION=false
GO_INCEPTION_HOST=goinception:4000

ORACLE_DRIVER_MODE=auto
ORACLE_CLIENT_LIB_DIR=
ORACLE_CLIENT_CONFIG_DIR=
